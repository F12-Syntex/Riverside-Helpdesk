# Copy to .env.local and fill in. .env.local is git-ignored.
OPENROUTER_API_KEY=sk-or-...
# Any model slug available on OpenRouter, e.g. anthropic/claude-sonnet-4.6
# Must be vision-capable: the RAG ingester reads images with this model (no OCR).
OPENROUTER_AI_MODEL=anthropic/claude-sonnet-4.6
# Embedding model for the knowledge base. OpenRouter serves it on the same key.
# Routed to Azure only (OpenRouter "Private": no training, no prompt retention).
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# Cheap model for query condensing and document summarising. Routed only to
# zero-retention providers (data_collection: deny). gpt-oss is a reasoning model.
OPENROUTER_ANALYSIS_MODEL=openai/gpt-oss-120b
