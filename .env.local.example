# Copy to .env.local and fill in. .env.local is git-ignored.
OPENROUTER_API_KEY=sk-or-...
# Any model slug available on OpenRouter, e.g. anthropic/claude-sonnet-4.6
# Must be vision-capable: the RAG ingester reads images with this model (no OCR).
OPENROUTER_AI_MODEL=anthropic/claude-sonnet-4.6
# Embedding model for the knowledge base. OpenRouter serves it on the same key.
# Routed to Azure only (OpenRouter "Private": no training, no prompt retention).
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# Cheap model for query condensing and document summarising. Routed only to
# zero-retention providers (data_collection: deny). gpt-oss is a reasoning model.
OPENROUTER_ANALYSIS_MODEL=openai/gpt-oss-120b
# The Medication Check tool (app/api/medication) calls OpenRouter's web-search
# server tool to gather information from authoritative UK sources (NHS, BNF/NICE,
# eMC). Web search is billed per request by OpenRouter on top of the model tokens;
# results are cached in Postgres (the `medications` table) so each medicine and
# question is only fetched once.
# It uses its own model so it can pick one that reliably returns grounded JSON
# with the web-search tool, without changing the global model above. It must
# support tool/function calling and response_format. Keep output price within
# budget — gpt-4.1-nano is ~$0.40 / 1M output tokens. Falls back to
# OPENROUTER_AI_MODEL if unset.
OPENROUTER_MEDICATION_MODEL=openai/gpt-4.1-nano

# --- Supplementary context (optional) ---------------------------------------
# Extra practice notes / triage instructions injected into answers at REQUEST
# TIME, so you can edit them without redeploying. They are added as citable
# Sources, so the assistant quotes them and the server verifies the quote.
#
# OneNote (auto-linked): read pages from your OneNote via Microsoft Graph. Get a
# refresh token once with `npm run onenote:auth` (see scripts/onenote-auth.mjs),
# then set these. Optionally limit which pages are read by notebook or section.
ONENOTE_CLIENT_ID=
ONENOTE_REFRESH_TOKEN=
# ONENOTE_TENANT=common          # use `consumers` for a personal-only account
# ONENOTE_CLIENT_SECRET=         # only if you registered a confidential client
# ONENOTE_NOTEBOOK=Reception     # only read pages in this notebook (by name)
# ONENOTE_SECTION=Triage         # only read pages in this section (by name)
#
# Any direct text/markdown/JSON URLs (comma or newline separated). Handy for a
# published note, a gist, or a OneDrive/SharePoint file with a direct-download link.
# SUPPLEMENTARY_CONTEXT_URLS=
#
# Seconds to cache supplementary context before re-fetching (default 300).
# SUPPLEMENTARY_CONTEXT_TTL=300
# Local baseline folder of committed notes (default rag/context). Editing these
# needs a redeploy, unlike the remote sources above.
# SUPPLEMENTARY_CONTEXT_LOCAL_DIR=rag/context

# Neon Postgres connection string (pooled endpoint). Used by the staff rota
# generator (lib/db.js) to store staff and saved rotas. Get it from the Neon
# dashboard. The unpooled/Postgres/Prisma variants Neon provides are optional.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
